@startuml diagrama-clases
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

packge "modelo.interfaces" {
    interface Consultable {
        + obtenerResumen() : String
        + estadoActivo() : boolean
        + obtenerTipo() : String
    }

    interface Transaccionable {
        + depositar(monto: double) : void
        + retirar(monto: double) : void
        + calcularComision(monto: double) : double
        + consultarSaldo() : double
    }

    interface Auditable {
        + obtenerFechaCreacion(): LocalDateTime
        + obtenerUltimaModificacion(): LocalDateTime
        + obtenerUsuarioModificacion(): String
        + registrarModificacion(usuario: String): void
    }

    interface Notificable {
        + notificar(mensaje: String): void
        + obtenerContacto(): String
        + aceptoNotificaciones(): boolean
    }
}

packge "modelo.enums" {
    enum EstadoTransaccion {
        PENDIENTE
        PROCESANDO
        COMPLETADA
        RECHAZADA
        REVERTIDA
    }

    enum TipoCuenta {
        CORRIENTE
        AHORRO
        CREDITO
    }

    enum Turno {
        MAÑANA
        TARDE
        NOCHE
    }

    enum TipoDocumento {
        CELUDA
        PASAPORTE
        NIT
        CELUDA_EXTRANJERIA
    }
}

package "modelo.excepciones" {
    class Excepcion <<checked>>
    class RuntimeExcepcion <<unchecked>>

    class SistemaBancarioException {
        - codigoError: String
        - timestamp: LocalDateTime
        + toString(): String
    }

    class BancoRuntimeException {
        + toString(): String
    }

    Excepction <|-- SistemaBancarioException
    SistemaBancarioException <|-- SaldoInsuficienteException
    SitemaBancarioException <|-- CuentaBloqueadaException
    SistemaBancarioException <|-- ClienteNoEncontradoException
    SistemaBancarioException <|-- CapacidadExcedidaException
}